# ONDEWO S2T NodeJS client — example configuration template.
#
# This is a NON-SECRET template committed to the repo. Copy it or fill in the
# blanks locally; never commit real credentials. Each example loads this file
# via dotenv using a path relative to the script, so the working directory does
# not matter.

# --- Connection -------------------------------------------------------------
# Host and port of the S2T gRPC server.
ONDEWO_HOST=localhost
ONDEWO_PORT=50051

# --- Secure channel ---------------------------------------------------------
# Open a TLS (secure) gRPC channel instead of plaintext. true/false.
ONDEWO_USE_SECURE_CHANNEL=false
# Path to a PEM root certificate for the TLS channel. Only used when
# ONDEWO_USE_SECURE_CHANNEL=true; leave blank for the system trust store.
ONDEWO_GRPC_CERT=

# --- Keycloak (bearer-token auth) -------------------------------------------
# Base Keycloak URL, realm and public OIDC client used for the offline-token
# login flow.
KEYCLOAK_URL=https://keycloak.example.com/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
# Technical-user credentials (2FA-exempt). Leave blank in the template.
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# Verify the Keycloak server's TLS certificate. Set to false only for a
# self-signed local Envoy. true/false.
KEYCLOAK_VERIFY_SSL=true
